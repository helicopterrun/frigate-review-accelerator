# Core server environment variables
# Copy to .env for local overrides (or set in your process manager / systemd unit).

# Internal URL the server uses to reach Frigate NVR.
# Defaults to http://192.168.50.207:5000 if unset.
# FRIGATE_URL=http://localhost:5000

# Client-facing Frigate URL embedded in HLS/VOD links sent to the browser.
# LOCAL DEV: leave unset — defaults to FRIGATE_URL (browser can reach it directly).
# PRODUCTION (nginx): set to the nginx proxy prefix so the browser never hits
#   the raw Frigate port (avoids mixed-content on HTTPS).
#   Example: FRIGATE_PUBLIC_URL=/frigate
#   Or full: FRIGATE_PUBLIC_URL=https://frigatebird.pondhouse.cloud/frigate
# FRIGATE_PUBLIC_URL=/frigate
