# Frontend environment variables
# Copy to .env.local for local overrides. Never commit .env.local.

# Core server URL (Socket.IO).
# LOCAL DEV: leave unset — vite.config.ts proxies /socket.io/ → localhost:4010
#   automatically, so no env var is needed.
# PRODUCTION (nginx): leave unset — the app connects to window.location.origin
#   and nginx proxies /socket.io/ to localhost:4010 (with WebSocket upgrade headers).
# Only set this if you need to point at a non-local core server.
# VITE_CORE_URL=http://localhost:4010

# Frigate NVR base URL (live JPEG feed + HLS snapshots).
# LOCAL DEV: leave unset — defaults to http://{hostname}:5000.
# PRODUCTION (nginx): leave unset — the app auto-detects HTTPS and uses /frigate,
#   which nginx proxies to localhost:5000. Only set this if your nginx prefix
#   differs from /frigate.
# VITE_FRIGATE_URL=/frigate
